{
	email {$ACME_EMAIL}
}

{$SITE_DOMAIN} {
	encode gzip zstd

	redir /memory /memory/ 308

	handle_path /memory/* {
		reverse_proxy memory-frontend:80
	}

	handle /api/* {
		reverse_proxy backend:8080
	}

	handle /uploads/* {
		reverse_proxy backend:8080
	}

	handle /internal/* {
		respond 404
	}

	handle {
		reverse_proxy frontend:80
	}
}
